@startuml architecture_global_v2
!theme plain
skinparam roundcorner 10
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

title MCPC: 航天器动力学与控制全局架构 (DDD + Class Fusion)

note top of "Mission_Sim_Framework"
  **总体架构设计哲学：二维正交解耦** 
  1. 静态空间维度：严格分离物理域、信息域与工具域。 
  2. 动态时间维度：核心类在各包内从 L1 向 L5 迭代升级，但包间的依赖契约保持不变。 
end note

package "Mission_Sim_Framework (工程根目录)" {

    ' ==========================================
    ' 第一层：仿真场景与主控引擎
    ' ==========================================
    package "scenarios (仿真场景层)" #FFF3E0 {
        class "Simulation_Runner" <<入口>> {
            + load_config()
            + init_components()
            + execute_time_loop()
        }
        note right of Simulation_Runner
          负责读取配置、组装 Core 组件、调用 Utils 工具，
          驱动时间步进主循环。(如 main_L1.py, main_L2.py) 
        end note
    }

    ' ==========================================
    ' 第二层：核心领域层 (各 Level 演进的主战场)
    ' ==========================================
    package "core (核心领域层)" #E3F2FD {
        
        package "types (全局契约基石)" #FFFFFF {
            enum CoordinateFrame {
                J2000_ECI
                SUN_EARTH_ROTATING
                LVLH  <<L2新增>>
            }
            class Telecommand {
                + type: String
                + target_state: Array
                + frame: CoordinateFrame
            }
            note top of CoordinateFrame
              **跨 L1-L5 全局复用** [cite: 2]
              绝对基石，防范坐标系错位的最后防线。
            end note
        }
        
        package "Physical_Domain (物理域)" #E8F8F5 {
            class CelestialEnvironment {
                + get_gravity_acceleration()
            }
            class SpacecraftPointMass <<L1, L2>> {
                + state: Array[6]
                + current_mass: Float
                + apply_thrust(force, frame)
                + get_derivative(grav, frame)
            }
            note bottom: 随等级演进：[cite: 3]\nL1: 质点 + CRTBP引力\nL2: 多体相对运动\nL4: 刚体姿态动力学\nL5: 挠性附件耦合 [cite: 3]
        }

        package "Information_Domain (信息域)" #FEF9E7 {
            class GroundStation {
                + track_spacecraft(real_state)
                + generate_telecommand()
            }
            class GNC_Subsystem {
                + estimated_state: Array[6]
                + compute_control_force(K_matrix)
            }
            class FormationManager <<L2新增>> {
                + chief: sc_id
                + deputies: List[sc_id]
                + broadcast_lvlh_state()
            }
            note bottom: 随等级演进：[cite: 4]\nL1: LQR绝对轨道维持\nL2: 编队相对导航\nL4: 姿轨联合高频控制 [cite: 4]
        }
    }

    ' ==========================================
    ' 第三层：基础设施层 (与物理级别解耦)
    ' ==========================================
    package "utils (基础设施层)" #E8F5E9 {
        class "MathTools (数学库)" {
            + get_lqr_gain(A, B, Q, R)
            + absolute_to_lvlh(r_c, v_c, r_d, v_d)
        }
        class "Loggers (数据持久化)" {
            + write_hdf5_timestep()
        }
        class "Visualizers (渲染)" {
            + plot_orbit_3d()
        }
        note bottom of MathTools
          **跨 L1-L5 全局复用** [cite: 4]
          它不关心卫星是怎么飞的，只负责算和画。 [cite: 4]
        end note
    }
}

' ==========================================
' 宏观依赖关系约束
' ==========================================
Physical_Domain .up.> types : 强制遵守 
Information_Domain .up.> types : 强制遵守 

scenarios --> core : 实例化与编排 
scenarios --> utils : 调用日志与绘图 

GNC_Subsystem ..> MathTools : "计算最优增益 K"

core -[hidden]-> utils
note right on link
  **依赖倒置原则 (DIP)**: 
  core 内部绝不能 import utils 里的绘图或落盘代码。 
  数据的产出(core)与数据的消费(utils)在主程序中通过 HDF5 桥接解耦。 
end note

@enduml