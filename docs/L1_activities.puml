@startuml
title MCPC 框架 L1 级业务流程活动图 (Activity Diagram)

skinparam ActivityBackgroundColor #F9F9F9
skinparam ActivityBorderColor #2C3E50
skinparam PartitionBackgroundColor #FFFFFF
skinparam PartitionBorderColor #BDC3C7
skinparam ArrowColor #2980B9

start

partition "1. 预处理阶段 (Pre-processing)" {
    :加载 L1 仿真配置 (轨道类型、总时长、步长 dt);
    :初始化 CelestialEnvironment (力学注册表);
    :根据轨道类型选择 TrajectoryGenerator 工厂;
    if (轨道类型?) then (开普勒)
        :KeplerianGenerator (二体解析);
    elseif (J2摄动)
        :J2KeplerianGenerator (数值积分+J2);
    elseif (平动点 Halo)
        :HaloDifferentialCorrector (微分修正);
    else (其他)
        :... 扩展生成器;
    endif
    :算法解算并生成全局标称轨道离散星历表 X_nominal(t);
    :初始化 SpacecraftPointMass 并注入初始偏差;
    :初始化 HDF5Logger;
    :（可选）注册力学模型: CRTBP / J2 / SRP / 大气阻力;
}

:进入时间推演主循环 (t = 0);

while (t < sim_time?) is (Yes)
    
    partition "2. 测量与信息层 (Perception)" {
        if (当前时间 t 是否在测控可视弧段内?) then (Yes)
            :GroundStation 获取物理真值;
            :注入轨道特异性定轨误差 (高斯白噪声);
            :生成带噪观测状态 X_obs;
            :从 X_nominal(t) 星历表插值获取当前标称状态;
            :封装为 Telecommand 发送给 GNC;
        else (No)
            :测控盲区：调用 GNC 内置外推器更新导航状态;
        endif
    }

    partition "3. 控制与算法层 (Logic)" {
        :GNC_Subsystem 接收导航状态与指令;
        :解算追踪误差 e(t) = X_nav(t) - X_nominal(t);
        :基于最优控制律 (如 LQR) 计算补偿力;
        :输出推力指令 F_cmd;
    }

    partition "4. 物理底座与执行层 (Plant & Actuation)" {
        :SpacecraftPointMass 接收并施加 F_cmd;
        :CelestialEnvironment 根据坐标系校验并计算总加速度\n(遍历已注册的力学模型: CRTBP/J2/SRP/大气阻力等);
        :汇总状态导数 (Velocity, Total_Acceleration);
        :执行数值动力学积分 (Runge-Kutta / Euler);
        :更新航天器物理真值状态;
        :积分推力时间，累加 ΔV 消耗量 (燃料账单);
        :清空本步作动器状态 (clear_thrust);
    }

    partition "5. 持久化 (Logging)" {
        if (达到降采样记录阈值?) then (Yes)
            :HDF5Logger 记录当前真值、追踪误差、推力与累计 ΔV;
            :触发缓存监测 (达到 Flush 阈值则落盘);
        else (No)
        endif
    }

    :推进时间 (t = t + dt);
endwhile (No)

partition "6. 后处理阶段 (Post-processing)" {
    :HDF5Logger 强制落盘 (Flush) 并关闭文件;
    :提取累计 ΔV，生成 Station Keeping 燃料基准底账;
    :（新增）将燃料账单写入 CSV/JSON 文件;
    :调用 Visualizer 生成 3D 标称轨道偏离度报告;
    :绘制 GNC 控制活动 (打火) 时序图;
}

stop
@enduml