@startuml
title MCPC 框架 L1 级静态类图 (基于代码实现 + 开发计划)

skinparam classAttributeIconSize 0
skinparam monochrome false
skinparam packageTitleAlignment center
skinparam shadowing false

' ==========================================
' 1. 类型与契约 (Types & Contracts)
' ==========================================
package "mission_sim.core.types" #F8F9FA {
    enum CoordinateFrame {
        J2000_ECI
        J2000_SSB
        WGS84_ECEF
        SUN_EARTH_ROTATING
        EARTH_MOON_ROTATING
        LVLH
        BODY_FRAME
    }

    class Telecommand {
        + cmd_type : str
        + target_state : np.ndarray
        + frame : CoordinateFrame
        + execution_epoch : float
        + __post_init__()
    }
}

' ==========================================
' 2. 预处理与星历 (Pre-processing)
' ==========================================
package "mission_sim.core.trajectory" #E8F8F5 {
    class Ephemeris {
        + times : np.ndarray
        + states : np.ndarray
        + frame : CoordinateFrame
        - _interpolator : CubicSpline
        + get_interpolated_state(t: float) : np.ndarray
        + __repr__()
    }

    abstract class BaseTrajectoryGenerator {
        + {abstract} generate(config: dict) : Ephemeris
    }

    package "generators" #E8F8F5 {
        class KeplerianGenerator {
            - mu : float
            + generate(config: dict) : Ephemeris
            - _kepler_solver(M: float, e: float) : float
        }

        class J2KeplerianGenerator {
            - mu : float
            - j2_model : J2Gravity
            + generate(config: dict) : Ephemeris
            - _elements_to_cartesian(elements) : np.ndarray
        }

        class HaloDifferentialCorrector {
            - mu : float
            - OMEGA : float
            - AU : float
            + generate(config: dict) : Ephemeris
            - _crtbp_equations(t, state) : np.ndarray
            - _find_period(state0) : float
            - _closure_conditions(state0, tf) : np.ndarray
            - _robust_initial_guess(Az) : tuple
        }

        BaseTrajectoryGenerator <|-- KeplerianGenerator
        BaseTrajectoryGenerator <|-- J2KeplerianGenerator
        BaseTrajectoryGenerator <|-- HaloDifferentialCorrector
        BaseTrajectoryGenerator ..> Ephemeris : <<creates>>
    }

    ' 工厂函数
    class TrajectoryFactory <<utility>> {
        + {static} create_generator(orbit_type: str, **kwargs) : BaseTrajectoryGenerator
    }
}

' ==========================================
' 3. 物理底座 (The Plant)
' ==========================================
package "mission_sim.core.physics" #EAEDED {
    class SpacecraftPointMass {
        + id : str
        + state : np.ndarray
        + frame : CoordinateFrame
        + mass : float
        + accumulated_dv : float
        + external_accel : np.ndarray
        + consumed_fuel : float
        + position : np.ndarray (property)
        + velocity : np.ndarray (property)
        + apply_thrust(force_vector: np.ndarray, force_frame: CoordinateFrame)
        + clear_thrust()
        + get_derivative(gravity_accel: np.ndarray, gravity_frame: CoordinateFrame) : np.ndarray
        + integrate_dv(dt: float)
        + consume_mass(m_dot: float, dt: float)
        + __repr__()
    }

    class CelestialEnvironment {
        + computation_frame : CoordinateFrame
        + epoch : float
        - _force_registry : list[IForceModel]
        + register_force(force_model: IForceModel)
        + step_time(dt: float)
        + get_total_acceleration(sc_state: np.ndarray, sc_frame: CoordinateFrame) : tuple[np.ndarray, CoordinateFrame]
        + __repr__()
    }

    interface IForceModel {
        + {abstract} compute_accel(state: np.ndarray, epoch: float) : np.ndarray
    }

    class Gravity_CRTBP {
        - mu : float
        - OMEGA : float
        - AU : float
        - GM_SUN : float
        - GM_EARTH : float
        - pos_sun : np.ndarray
        - pos_earth : np.ndarray
        + compute_accel(state: np.ndarray, epoch: float) : np.ndarray
    }

    class J2Gravity {
        - mu_earth : float
        - j2 : float
        - r_earth : float
        - _prefactor : float
        + compute_accel(state: np.ndarray, epoch: float) : np.ndarray
    }

    class Cannonball_SRP {
        - area_to_mass : float
        - reflectivity : float
        - AU : float
        - mu : float
        - P_solar : float
        - sun_position : np.ndarray
        - _constant_factor : float
        + compute_accel(state: np.ndarray, epoch: float) : np.ndarray
    }

    class AtmosphericDrag {
        - area_to_mass : float
        - Cd : float
        - rho0 : float
        - scale_height : float
        + compute_accel(state: np.ndarray, epoch: float) : np.ndarray
    }

    CelestialEnvironment o-- IForceModel
    IForceModel <|.. Gravity_CRTBP
    IForceModel <|.. J2Gravity
    IForceModel <|.. Cannonball_SRP
    IForceModel <|.. AtmosphericDrag
}

' ==========================================
' 4. 感知与控制 (Perception & Logic)
' ==========================================
package "mission_sim.core.gnc" #FDF2E9 {
    class GroundStation {
        + name : str
        + operating_frame : CoordinateFrame
        + pos_noise_std : float
        + vel_noise_std : float
        - sampling_rate_hz : float
        - min_interval : float
        - last_track_time : float
        - visibility_windows : list[tuple[float, float]]
        + is_visible(epoch: float) : bool
        + track_spacecraft(true_state: np.ndarray, sc_frame: CoordinateFrame, epoch: float) : tuple[np.ndarray | None, CoordinateFrame]
        + generate_telecommand(cmd_type: str, target_state: np.ndarray, target_frame: CoordinateFrame, execution_epoch: float = 0.0) : Telecommand
        + __repr__()
    }

    abstract class Propagator {
        + {abstract} propagate(state: np.ndarray, dt: float) : np.ndarray
    }

    class SimplePropagator {
        + propagate(state: np.ndarray, dt: float) : np.ndarray
    }

    class KeplerPropagator {
        - mu : float
        + propagate(state: np.ndarray, dt: float) : np.ndarray
    }

    class GNC_Subsystem {
        + sc_id : str
        + operating_frame : CoordinateFrame
        - current_nav_state : np.ndarray
        - ref_ephemeris : Ephemeris | None
        - _propagator : Propagator | None
        - last_control_force : np.ndarray
        - last_tracking_error : np.ndarray
        - last_target_state : np.ndarray
        - total_control_calls : int
        - force_shape_warnings : int
        + load_reference_trajectory(eph: Ephemeris)
        + update_navigation(obs_state: np.ndarray, frame: CoordinateFrame, dt: float = 0.0)
        + compute_control_force(epoch: float, K_matrix: np.ndarray) : tuple[np.ndarray, CoordinateFrame]
        + set_propagator(propagator: Propagator)
        + get_tracking_error(epoch: float) : np.ndarray
        + get_performance_metrics() : dict
        + reset()
        + __repr__()
    }

    GNC_Subsystem o-- Ephemeris : 追踪参考轨迹
    GNC_Subsystem o-- Propagator : 盲区外推
    Propagator <|-- SimplePropagator
    Propagator <|-- KeplerPropagator
}

' ==========================================
' 5. 基础设施与编排 (Infra & Orchestrator)
' ==========================================
package "mission_sim.utils" #F5EEF8 {
    class HDF5Logger {
        - filepath : str
        - buffer_size : int
        - compression : bool
        - auto_flush : bool
        - buffers : dict
        - buffer_count : int
        - is_initialized : bool
        - total_steps : int
        + initialize_file(metadata: dict | None)
        + log_step(epoch: float, nominal_state: np.ndarray, true_state: np.ndarray, nav_state: np.ndarray, tracking_error: np.ndarray, control_force: Union[np.ndarray, float], accumulated_dv: float)
        + flush() : int
        + close() : bool
        + get_statistics() : dict
        + load_data(dataset_name: str, start_idx: int = 0, end_idx: int = None) : np.ndarray
        + load_all_data() : dict
    }

    class BaseVisualizer {
        + filepath : str
        + default_figsize : tuple
        + create_figure(rows: int, cols: int, title: str, figsize: tuple = None) : tuple[plt.Figure, plt.Axes]
        + save_plot(fig_obj: plt.Figure, save_path: str)
        + load_dataset(dataset_path: str) : np.ndarray
    }

    class L1Visualizer {
        - mission_name : str
        + plot_3d_trajectory(save_path: str = "data/L1_3d_trajectory.png")
        + plot_tracking_error(save_path: str = "data/L1_tracking_error.png")
        + plot_control_effort(save_path: str = "data/L1_control_effort.png")
    }

    BaseVisualizer <|-- L1Visualizer
}

class L1MissionSimulation <<Orchestrator>> {
    - config : dict
    - mission_id : str
    - h5_file : str
    - simulation_start_time : float | None
    - simulation_end_time : float | None
    - current_step : int
    - total_steps : int
    - environment : CelestialEnvironment
    - spacecraft : SpacecraftPointMass
    - ground_station : GroundStation
    - gnc_system : GNC_Subsystem
    - ephemeris : Ephemeris
    - logger : HDF5Logger
    - k_matrix : np.ndarray
    + run() : bool
    + get_statistics() : dict
    - _generate_nominal_orbit() : bool
    - _generate_fallback_orbit()
    - _initialize_physical_domain()
    - _initialize_information_domain()
    - _design_control_law()
    - _execute_simulation_loop()
    - _finalize_simulation() : bool
    - _report_progress(step: int, epoch: float, force_cmd: np.ndarray)
    - _ensure_3d_control_force(force_cmd) : np.ndarray
    - _get_state_derivative(state: np.ndarray) : np.ndarray
}

' ==========================================
' 顶层依赖与组合关系
' ==========================================
L1MissionSimulation *-- CelestialEnvironment
L1MissionSimulation *-- SpacecraftPointMass
L1MissionSimulation *-- GroundStation
L1MissionSimulation *-- GNC_Subsystem
L1MissionSimulation *-- HDF5Logger
L1MissionSimulation ..> TrajectoryFactory : 使用工厂创建生成器

@enduml